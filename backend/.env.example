# App
APP_NAME=Eloq Backend
ENVIRONMENT=development
DEBUG=true

# Database (Supabase Postgres; include sslmode=require)
DATABASE_URL=postgresql+psycopg2://postgres.<project_ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require

# JWT
JWT_SECRET_KEY=replace_with_long_random_256_bit_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=openai/gpt-oss-120b

# TTS (Groq API for Text-to-Speech)
GROQ_TTS_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_TTS_MODEL=canopylabs/orpheus-v1-english
GROQ_TTS_VOICE=austin

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_AUDIO_FOLDER=eloq/audio

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Whisper
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
